<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView android:id="@+id/tv_admin_name"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="16sp" android:textStyle="bold" android:textColor="#212121"/>
            <TextView android:id="@+id/tv_admin_price"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="14sp" android:textColor="#FF5722" android:layout_marginTop="2dp"/>
            <TextView android:id="@+id/tv_admin_desc"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#888888" android:layout_marginTop="2dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <Button android:id="@+id/btn_admin_edit"
                android:layout_width="70dp" android:layout_height="36dp"
                android:text="✏ Sửa" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#2196F3"
                android:layout_marginBottom="4dp"/>
            <Button android:id="@+id/btn_admin_delete"
                android:layout_width="70dp" android:layout_height="36dp"
                android:text="🗑 Xóa" android:textSize="11sp"
                android:textColor="#FFFFFF" android:backgroundTint="#F44336"/>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>